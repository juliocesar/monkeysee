{
  "manifest_version": 3,
  "name": "MonkeySee Browser Agent",
  "version": "0.0.1",
  "description": "Lets an MCP client drive this browser.",
  "permissions": ["tabs", "scripting", "webNavigation", "activeTab", "storage", "alarms", "debugger"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js", "type": "module" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": { "default_popup": "popup.html" },
  "icons": { "16": "icons/16.png", "48": "icons/48.png", "128": "icons/128.png" }
}
