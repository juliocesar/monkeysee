{
  "name": "extension",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "package": "node build.mjs && cd dist && zip -r ../monkeysee-extension.zip . -x '*.map'"
  },
  "dependencies": {
    "@monkeysee/protocol": "workspace:*"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.0",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.0"
  }
}
