{
  "name": "monkeysee-bridge",
  "version": "0.2.0",
  "description": "MCP server that lets an MCP client (Claude Code, Codex, any MCP client) drive a real, logged-in Chrome profile. Ships the MonkeySee Chrome extension bundled.",
  "license": "MIT",
  "author": "Julio Cesar Ody <julio@supernormal.com>",
  "homepage": "https://github.com/juliocesar/monkeysee#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juliocesar/monkeysee.git",
    "directory": "packages/bridge"
  },
  "bugs": "https://github.com/juliocesar/monkeysee/issues",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "browser-automation",
    "chrome-extension",
    "claude-code",
    "codex",
    "monkeysee"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "monkeysee-bridge": "dist/index.js"
  },
  "files": [
    "dist",
    "scripts"
  ],
  "scripts": {
    "build": "node build.mjs && tsc -p tsconfig.build.json",
    "postinstall": "node scripts/postinstall.mjs",
    "dev": "node build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "test": "node test/e2e.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "monkeysee-protocol": "workspace:*",
    "ws": "^8.18.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^6.0.0",
    "esbuild": "^0.28.0"
  }
}
